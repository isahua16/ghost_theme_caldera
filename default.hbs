<html lang="{{@site.locale}}">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="stylesheet" href="{{asset 'built/index.css'}}" />
        <script src="{{asset 'built/index.js'}}" defer></script>

        <title>{{meta_title}}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        {{ghost_head}}
        {{! Outputs important meta data and settings, should always be in <head> }}

    </head>
    <body class="{{body_class}}">
        <div class="gh-viewport">

            <header id="gh-head" class="gh-head">
                <nav class="gh-head-inner gh-container">

                    <div class="gh-head-brand">
                        <a class="gh-head-logo" href="{{@site.url}}">
                            {{#if @site.logo}}
                                <img
                                    src="{{@site.logo}}"
                                    alt="{{@site.title}}"
                                />
                            {{else}}
                                {{@site.title}}
                            {{/if}}
                        </a>
                        <a class="gh-burger" role="button" aria-label="menu">
                            <div class="gh-burger-box">
                                <div class="gh-burger-inner"></div>
                            </div>
                        </a>
                    </div>
                    <div class="gh-head-menu">
                        {{navigation}}
                        <a
                            class="gh-head-wishlist"
                            href="https://store.steampowered.com/app/4439600/The_Rabbit_Haul_Demo/"
                            target="_blank"
                            rel="noopener"
                        >
                            Wishlist on Steam
                        </a>
                    </div>
                </nav>

            </header>
            <div class="blue-bar"></div>

            <main class="gh-main">

                {{{body}}}
                {{! All content gets inserted here, index.hbs, post.hbs, etc }}

            </main>

            <footer class="gh-foot">
                <div class="gh-container">
                    <div class="gh-foot-main">
                        <div class="gh-foot-brand">
                            {{#if @site.logo}}
                                <a
                                    class="gh-foot-logo-link"
                                    href="{{@site.url}}"
                                    aria-label="{{@site.title}} home"
                                >
                                    <img
                                        class="gh-foot-logo"
                                        src="{{@site.logo}}"
                                        alt="{{@site.title}}"
                                    />
                                </a>
                            {{else}}
                                <p class="gh-foot-title">{{@site.title}}</p>
                            {{/if}}
                            <p>Wholesome games from Edmonton.</p>
                            <div class="gh-foot-socials">
                                <a
                                    target="_blank"
                                    href="https://bsky.app/profile/calderainteractive.bsky.social"
                                ><img
                                        class="social_icon"
                                        src="{{asset 'images/bluesky.svg'}}"
                                        alt="Bluesky logo"
                                    /></a>
                                <a
                                    target="_blank"
                                    href="https://twitter.com/CalderaInteract"
                                >
                                    <img
                                        class="social_icon"
                                        src="{{asset 'images/twitter.svg'}}"
                                        alt="X Logo"
                                    />
                                </a>
                                <a
                                    target="_blank"
                                    href="https://discord.gg/UVDt2ScaDJ"
                                >
                                    <img
                                        class="social_icon"
                                        src="{{asset 'images/discord.svg'}}"
                                        alt="Discord logo"
                                    />
                                </a>
                                <a
                                    target="_blank"
                                    href="https://www.youtube.com/@calderainteractive"
                                >
                                    <img
                                        class="social_icon"
                                        src="{{asset 'images/youtube.svg'}}"
                                        alt="Youtube logo"
                                    />
                                </a>
                                <a
                                    target="_blank"
                                    href="https://store.steampowered.com/app/2514330/The_Rabbit_Haul/"
                                >
                                    <img
                                        class="social_icon"
                                        src="{{asset 'images/steam.svg'}}"
                                        alt="Steam logo"
                                    />
                                </a>
                                <a
                                    target="_blank"
                                    href="https://www.instagram.com/calderainteractive/"
                                >
                                    <img
                                        class="social_icon"
                                        src="{{asset 'images/instagram.svg'}}"
                                        alt="Instagram logo"
                                    />
                                </a>
                                <a
                                    target="_blank"
                                    href="https://www.tiktok.com/@rabbithaulgame"
                                >
                                    <img
                                        class="social_icon"
                                        src="{{asset 'images/tiktok.svg'}}"
                                        alt="TikTok logo"
                                    />
                                </a>
                            </div>
                        </div>

                        <div class="gh-foot-menu">
                            <p class="gh-foot-heading">Explore</p>
                            {{navigation type="secondary"}}
                        </div>

                        <div class="gh-foot-legal">
                            <p class="gh-foot-heading">Legal</p>
                            <nav aria-label="Legal links">
                                <ul class="gh-foot-link-list">
                                    <li><a href="/privacy">Privacy</a></li>
                                    <li><a href="/terms">Terms</a></li>
                                    <li><a href="/eula">EULA</a></li>
                                    <li>
                                        <button
                                            class="cookie-settings-button"
                                            type="button"
                                            data-cookie-settings
                                        >Cookie Settings</button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="gh-foot-meta">
                        <p>&copy {{year}} Caldera Interactive Ltd.</p>
                    </div>
                </div>
            </footer>

        </div>

        {{! <foot> }}
        {{ghost_foot}}
        {{! Outputs important scripts - should always be included before closing body tag }}

    </body>
</html>
