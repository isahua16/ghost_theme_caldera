{{!< default}}
{{#if @member}}
    <div class="welcome-page-header">
        <div class="welcome-page-header-container">
            <h1 class="welcome-page-header-title">
                Welcome
                <span class="watermelon-text">Watermelon Warrior!</span>
            </h1>
        </div>
    </div>
    <div class="gh-page">
        <div class="gh-container">
            <div class="welcome-page-container">
                <div class="welcome-page-membership-section-container">
                    <h4 class="welcome-page-membership-section-title">How to
                        Claim Your Prizes!
                    </h4>
                    <ul class="welcome-page-membership-section-list">
                        <li>Download The Rabbit Haul Demo on
                            <a
                                href="https://store.steampowered.com/app/4439600/The_Rabbit_Haul_Demo/"
                                target="_blank"
                                rel="noopener noreferrer"
                            >Steam</a></li>
                        <li>From the game, enter this code
                            <strong>waterwarrior_super_secret_code</strong>
                            under Settings -> Code Redemption</li>
                        <li>Look absolutely
                            <strong>S T U N N I N G !</strong>
                        </li>
                        <li>Join our official
                            <a
                                href="https://discord.gg/tzNAwGBqT7"
                                target="_blank"
                                rel="noopener noreferrer"
                            >Discord</a>
                            to show off your exclusive Discord role
                        </li>
                        <li>
                            Wait patiently for the next newsletter at the start
                            of each month! (we promise they are worth it😉)</li>
                        <li>Share the Watermelon love on socials and tag us! We
                            want to see you rocking it as you take down the
                            Trash Panda Posse 🍉⚔️
                        </li>
                    </ul>
                </div>

                <div class="welcome-page-playtest-section-container">
                    <h4 class="welcome-page-playtest-section-title">Private
                        Betas
                    </h4>
                    <ul class="welcome-page-playtest-section-list">
                        <li>Our next playtest is
                            <strong>TBD</strong></li>
                        <li>By joining our
                            <a
                                href="https://discord.gg/tzNAwGBqT7"
                                target="_blank"
                                rel="noopener noreferrer"
                            >Discord</a>, you will be the first to try out all
                            the new content in our game</li>
                        <li>We run playtests regularly so don't worry about
                            missing out! Keep an eye on your inbox so you can
                            help shape The Rabbit Haul leading all the way up to
                            launch!</li>
                    </ul>
                </div>

                <div class="welcome-page-discord-section-container">
                    <a
                        href="https://discord.gg/tzNAwGBqT7"
                        target="_blank"
                        rel="noopener noreferrer"
                    ><img
                            class="welcome-page-discord-section-button-image"
                            src="{{asset 'images/discord.webp'}}"
                            alt="Click button to join Discord"
                        /></a>
                    <p class="welcome-page-discord-section-text">By signing up,
                        you agree to our
                        <a
                            href="/terms"
                        >terms</a>.</p>
                </div>
            </div>
        </div>
    </div>
{{else}} 
    <div class="subscribe-page-header">
        <div class="subscribe-page-header-container">
            <h1 class="subscribe-page-header-title">
                Become a
                <span class="watermelon-text">Watermelon Warrior</span>
                🍉</h1>
        </div>
    </div>
    <div class="gh-page">
        <div class="gh-container">
            <div class="subscribe-page-signup-section">
                <img
                    class="subscribe-page-signup-image"
                    src="{{asset 'images/watermelon.webp'}}"
                    alt="Image of a sprout wearing the watermelon helmet cosmetic"
                />
                <div class="subscribe-page-signup-form-container">
                    <div class="subscribe-page-signup-form-title">
                        <h1>Subscribe Now</h1>
                        <p class="subscribe-page-signup-form-subtitle">Signing
                            up has its perks ! 🎉</p>
                    </div>
                    <ul class="subscribe-page-signup-form-perks-section">
                        <li>Unlock watermelon helmet cosmetic and live your best
                            Catbbit life</li>
                        <li>Get exclusive Watermelon Warrior role in our
                            official Discord</li>
                        <li>Gain access to our game betas</li>
                        <li>SLAAY! SLAY YOUR ENEMIES!</li>
                        <li>Receive monthly newsletters full of the latest
                            updates!</li>
                    </ul>
                    <div class="subscribe-page-signup-form-email-container">
                        <div
                            class="subscribe-page-signup-form-email-input"
                        >
                            <form
                                class="subscribe-page-signup-form"
                                data-members-form="signup"
                            >
                                <div class="gh-auth-box">
                                    <input
                                        class="gh-input"
                                        data-members-email
                                        type="email"
                                        required="true"
                                        autocomplete="email"
                                        placeholder="you@example.com"
                                        aria-label="Email address"
                                    />
                                    <button
                                        class="gh-button gh-button-primary"
                                        type="submit"
                                    >
                                        <span
                                            class="gh-button-content"
                                        >Subscribe</span>
                                        <span class="gh-button-loader">
                                            {{> "icons/loader"}}
                                        </span>
                                    </button>
                                </div>
                                <p class="message-success">
                                    Great! Check your inbox and click the link
                                    to confirm your signup.
                                </p>
                                <p
                                    class="message-error"
                                    data-members-error
                                ></p>
                            </form>
                        <p
                            class="subscribe-page-signup-form-email-disclaimer"
                        >By signing up, you agree to our
                            <a
                                href="/terms"
                            >terms</a>.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{{/if}}
